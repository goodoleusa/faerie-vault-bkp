updated: {{ moment().format('YYYY-MM-DD') }}
tags: [brief, {{ brief_type }}, {{ run_id }}]
investigation_id: {{ investigation_id }}
sprint_id: {{ sprint_id }}
session_id: {{ session_id }}
run_id: {{ run_id }}
