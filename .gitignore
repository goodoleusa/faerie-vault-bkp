# Obsidian cache & temp files
.obsidian/cache/
.obsidian/workspace
.obsidian/*.json
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
!.obsidian/community-plugins.json
!.obsidian/hotkeys.json
!.obsidian/command-palette.json
!.obsidian/agent-config.json

# Plugin node_modules (reinstalled on vault open)
.obsidian/plugins/*/node_modules/
.obsidian/plugins/**/package-lock.json
.obsidian/plugins/hive-pdf/

# Large cache files
.obsidian/copilot-index-*.json

# Generated files
.obsidian/graph.json
.obsidian/daily-notes.json
.obsidian/switcher.json
.obsidian/templates.json
.obsidian/backlink.json

# Theme files (users choose their own)
.obsidian/themes/*/

# System files
.DS_Store
Thumbs.db
*.tmp

# Git files
.git/
.gitignore

# Plugin secrets (API keys, license keys in plaintext)
.obsidian/plugins/share-note/data.json
.obsidian/plugins/copilot/data.json
